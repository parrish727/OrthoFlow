# OrthoFlow AI — Environment Variables
# Copy to .env and fill in values

# Database
POSTGRES_USER=orthoflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=orthoflow
DATABASE_URL=postgresql://orthoflow:changeme@postgres:5432/orthoflow

# Redis
REDIS_URL=redis://redis:6379/0

# Object Storage (MinIO locally, S3 in prod)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=orthoflow
S3_SECRET_KEY=changeme123
S3_BUCKET=invoices

# LLM — abstraction layer switches between local and cloud
# Options: ollama | litellm | bedrock
LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# AWS Bedrock (prod only)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Email ingestion
INBOUND_EMAIL_DOMAIN=invoices.orthoflow.local

# Auth
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# QuickBooks (future)
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REDIRECT_URI=
